# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True
ENVIRONMENT=development  # Set to 'production' when deploying

# API Keys
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
UNSPLASH_SECRET_KEY=your_unsplash_secret_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# Database
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=exploreidea
REDIS_URL=redis://localhost:6379

# CLIP Model
CLIP_MODEL_NAME=ViT-B/32
DEVICE=cpu  # or 'cuda' if GPU available

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
# In production, set this to your Vercel frontend URL
# Example: ALLOWED_ORIGINS=https://exploreidea.vercel.app,https://www.yoursite.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Cache
CACHE_TTL=3600
MAX_CACHE_SIZE=1000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
